# ========== Pelican 构建输出（必须忽略） ==========
/output/               # 生成的静态网站文件，体积大且可重建
/.pelican/             # 某些缓存目录（如果有）

# ========== Python 虚拟环境（本地环境相关） ==========
/venv/
/env/
/.venv/
/.virtualenvs/
# 如果你的项目使用 pipenv，可能还有 Pipfile.lock（但建议保留以锁定依赖，也可忽略）
/Pipfile.lock         # 可选项，若你希望每次重新生成依赖，可忽略

# ========== Python 缓存 & 编译文件 ==========
__pycache__/
*.py[cod]
*.pyc
*.so
.pytest_cache/
.coverage
htmlcov/

# ========== 编辑器/操作系统临时文件 ==========
.DS_Store
Thumbs.db
*.swp
*.swo
*~
*.log
*.tmp

# ========== 其它可能产生的临时文件 ==========
*.pid
*.seed
*.pid.lock
